# ===========================================
# Docker Build Ignore
# ===========================================

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# TypeScript
dist/
*.tsbuildinfo

# 开发文件
.git/
.gitignore
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# 测试
test/
tests/
coverage/
*.test.js
*.spec.js

# 文档
README.md
docs/
*.md

# Docker
Dockerfile*
docker-compose*
.dockerignore

# 日志
logs/
*.log

# 数据（不应该被打包）
data/
*.db
*.sqlite

# 其他
.DS_Store
Thumbs.db
