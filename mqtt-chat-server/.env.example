# ===========================================
# MQTT Chat Server 环境变量配置
# ===========================================
# 复制此文件为 .env 并填写实际值
# 开发环境可以留空，会使用默认值

# ===========================================
# 服务器配置
# ===========================================

# HTTP 服务端口
HTTP_PORT=14070

# MQTT TCP 端口
MQTT_PORT=14080

# MQTT WebSocket 端口
MQTT_WS_PORT=14083

# 运行环境（development / production）
NODE_ENV=development

# 日志级别（debug / info / warn / error）
LOG_LEVEL=info

# ===========================================
# JWT 配置（生产环境必须设置）
# ===========================================

# JWT 密钥（至少32个字符）
# ⚠️ 必须修改为随机值！
# 生成随机密钥命令: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<YOUR_JWT_SECRET_HERE>

# Token 过期时间
JWT_EXPIRES_IN=7d

# ===========================================
# 数据库配置
# ===========================================

# 数据库文件路径
DB_PATH=./data/chat.db

# ===========================================
# CORS 配置
# ===========================================

# 允许的跨域来源（生产环境应该设置具体域名）
CORS_ORIGIN=*

# ===========================================
# 安全配置
# ===========================================

# 启用/禁用速率限制
ENABLE_RATE_LIMIT=true

# API 请求速率限制（每15分钟）
API_RATE_LIMIT=100

# 登录尝试限制（每15分钟）
LOGIN_RATE_LIMIT=5
